#!/usr/bin/env bash
MSG=$(cat "$1")
echo "$MSG" | grep -qE '^(feat|fix|refactor|docs|test|ci|chore|perf|style)(\(.+\))?: .+' || {
  echo "ERROR: Commit message must follow conventional commits"
  echo "Format: <type>(<scope>): <description>"
  echo "Example: feat(config): add TOML parsing"
  exit 1
}
